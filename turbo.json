{
	"$schema": "https://turborepo.com/schema.json",
	"ui": "tui",
	"globalDependencies": [".env", ".env.*"],
	"globalEnv": [
		"NODE_ENV",
		"DATABASE_URL",
		"POSTGRES_URL_NON_POOLING",
		"PGDATABASE",
		"POSTGRES_PRISMA_URL",
		"POSTGRES_URL",
		"PGUSER",
		"PGPASSWORD",
		"BETTER_AUTH_SECRET",
		"BETTER_AUTH_URL",
		"GITHUB_APP_ID",
		"GITHUB_APP_PRIVATE_KEY",
		"GITHUB_APP_INSTALLATION_ID",
		"GITHUB_CLIENT_ID",
		"GITHUB_CLIENT_SECRET",
		"VITE_GITHUB_APP_SLUG",
		"AUTUMN_SECRET_KEY",
		"UNKEY_ROOT_KEY",
		"OPENROUTER_API_KEY",
		"OPENAI_API_KEY",
		"TRIPWIRE_AI_MODEL"
	],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["src/**", "tsconfig.json", "package.json"],
			"outputs": [".output/**", ".tanstack/**", "dist/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"lint": {
			"dependsOn": ["^build"],
			"outputs": []
		},
		"typecheck": {
			"dependsOn": ["^build"],
			"inputs": ["src/**", "tsconfig.json"],
			"outputs": []
		},
		"test": {
			"dependsOn": ["^build"],
			"inputs": ["src/**", "test/**", "tests/**", "*.test.ts", "*.test.tsx"],
			"outputs": []
		},
		"clean": {
			"cache": false
		},
		"db:generate": {
			"cache": false,
			"inputs": ["src/db/**"],
			"outputs": ["drizzle/**"]
		},
		"db:migrate": {
			"cache": false
		},
		"db:push": {
			"cache": false
		},
		"db:studio": {
			"cache": false,
			"persistent": true
		}
	}
}
