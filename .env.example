# Each var below is tagged [required] or [optional].
# [optional] vars can be left blank — the related feature is simply disabled.
# [required in prod] vars are only enforced when NODE_ENV=production.

BETTER_AUTH_URL="http://localhost:3000"
# [required in prod] Must be a strong unique value (not "tripwire") in production.
BETTER_AUTH_SECRET=  # generate with: openssl rand -hex 32

# [required] GitHub OAuth App — user login does not work without these.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub App (for webhooks + API actions)
# [required] App ID — GitHub App actions need this.
GITHUB_APP_ID=
# [required in prod] Private key for signing GitHub App requests.
GITHUB_APP_PRIVATE_KEY=
# [required in prod] Secret for verifying inbound webhook payloads.
GITHUB_WEBHOOK_SECRET=

# [optional] GitHub App slug for the installation URL (github.com/apps/{slug}).
VITE_GITHUB_APP_SLUG=tripwire-dev

# [optional] Dev-only UI tooling (only applies when vite is in development mode).
# Values: true/false or 1/0 (strings). Omit or false = disabled.
# VITE_REACT_SCAN_ENABLED=true
# VITE_REACT_GRAB_ENABLED=true

# [required in prod] Postgres connection string.
DATABASE_URL=

# [optional] Unkey rate limiting — allows all requests if not set.
UNKEY_ROOT_KEY=

# [optional] Autumn billing.
AUTUMN_SECRET_KEY=

# [optional] OpenRouter — powers AI chat. Chat features are disabled if unset.
OPENROUTER_API_KEY=
# [optional] Model overrides. Defaults are used when unset.
# TRIPWIRE_AI_MODEL=openai/gpt-5.4
# TRIPWIRE_TITLE_MODEL=

# [optional] Axiom — used for both evlog wide events and OpenTelemetry traces.
# Create two datasets in Axiom: one for events (logs), one for traces.
AXIOM_TOKEN=
AXIOM_DATASET=
AXIOM_TRACES_DATASET=

# [optional] OpenTelemetry traces — set the endpoint to your Axiom edge domain.
# e.g. https://api.axiom.co  (the SDK appends /v1/traces automatically)
OTEL_EXPORTER_OTLP_ENDPOINT=https://api.axiom.co
# [optional] Extra headers as "K1=V1,K2=V2". AXIOM_TOKEN and AXIOM_TRACES_DATASET
# above are wired automatically, so this only needs to be set for non-Axiom backends.
OTEL_EXPORTER_OTLP_HEADERS=

# [optional] Trace sampling. Defaults to AlwaysOn (every trace exported). When volume
# becomes a concern, switch to `parentbased_traceidratio` and set the ratio.
# OTEL_TRACES_SAMPLER=parentbased_traceidratio
# OTEL_TRACES_SAMPLER_ARG=0.1   # keep 10% of root traces

# [optional] Inngest — durable background jobs (research runs, future async work).
# In local dev: leave blank and run `npx inngest-cli dev` for the dev proxy.
# In prod: grab keys from https://app.inngest.com.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# [optional] Branch environment name. Required when your event/signing keys belong
# to a branch env (not "production") — otherwise Inngest returns
# "400 Branch environment name is required". Leave blank for production.
# Example: INNGEST_ENV=staging  or  INNGEST_ENV=preview-pr-42
INNGEST_ENV=

# [optional] Research eval harness — admin tool that runs the signal pipeline against
# thousands of GitHub contributors to build a labeled dataset for ML / research.
# Uses a Personal Access Token (NOT the GitHub App) so it can read PR data
# from any public repo, whether the GH App is installed there or not.
# Needs `public_repo` scope. Create at https://github.com/settings/tokens.
RESEARCH_GH_TOKEN=
